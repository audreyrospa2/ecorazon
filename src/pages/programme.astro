---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Our Works - Ecorazón">
  <Header />

  <main class="works-page">

    <!-- Hero -->
    <section class="works-hero">
      <div class="works-hero-content">
        <h1 class="works-hero-title animate-fade-in">Our Works</h1>
        <p class="works-hero-sub animate-fade-in-delay">Discover the beautiful creations born from the collaboration between our talented artists and valued partners.</p>
      </div>
    </section>

    <!-- Intro -->
    <section class="wrk-section bg-white">
      <div class="wrk-inner">
        <h2 class="section-title scroll-reveal">Our Work Speaks for Itself</h2>
        <p class="intro-text scroll-reveal">
          Explore some of the bespoke creations we've crafted in collaboration with our talented artists and valued partners. Each piece tells a unique story of sustainability, creativity, and empowerment.
        </p>
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="wrk-section bg-white">
      <div class="wrk-inner">
        <div class="featured-grid">

          <div class="project-card scroll-reveal">
            <div class="project-img-wrap">
              <img src="/images/4.png" alt="Sustainable Corporate Gift Set" class="project-img" />
            </div>
            <div class="project-info">
              <div class="project-meta">
                <span class="project-tag green">Corporate Gifts</span>
                <span class="project-year">Completed 2024</span>
              </div>
              <h3 class="project-name">Sustainable Corporate Gift Set</h3>
              <p class="project-materials">Materials: Cork, Recycled Plastic Bottles</p>
              <p class="project-desc">A beautifully designed custom gift set that reflects the client's commitment to ESG goals while supporting our special needs artists. This project showcased how corporate responsibility can be transformed into tangible, meaningful gifts.</p>
              <div class="project-tags">
                <span class="tag">Sustainability</span>
                <span class="tag">Cork Materials</span>
                <span class="tag">ESG Impact</span>
              </div>
            </div>
          </div>

          <div class="project-card scroll-reveal">
            <div class="project-img-wrap">
              <img src="/images/16.jpg" alt="Co-Branded Merchandise" class="project-img" />
            </div>
            <div class="project-info">
              <div class="project-meta">
                <span class="project-tag olive">Co-Branded</span>
                <span class="project-year">Completed 2024</span>
              </div>
              <h3 class="project-name">Co-Branded Merchandise</h3>
              <p class="project-materials">Materials: Seed Paper, Coffee Grounds</p>
              <p class="project-desc">A co-branded initiative that merged art and sustainability to create a memorable corporate gift. This collaboration demonstrated how partnerships can amplify impact while creating products that recipients treasured and remembered.</p>
              <div class="project-tags">
                <span class="tag">Collaboration</span>
                <span class="tag">Seed Paper</span>
                <span class="tag">Innovation</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Portfolio Grid -->
    <section class="wrk-section bg-white">
      <div class="wrk-inner">
        <div class="portfolio-grid">

          <div class="portfolio-card scroll-reveal">
            <div class="portfolio-img-wrap">
              <img src="/images/17.jpg" alt="Eco-Friendly Office Set" class="portfolio-img" />
            </div>
            <div class="portfolio-info">
              <span class="project-tag brown">Branded Merchandise</span>
              <h4 class="portfolio-name">Eco-Friendly Office Set</h4>
              <p class="portfolio-materials">Bamboo, Recycled Materials</p>
              <p class="portfolio-desc">Sustainable office accessories that promote environmental consciousness in the workplace.</p>
            </div>
          </div>

          <div class="portfolio-card scroll-reveal">
            <div class="portfolio-img-wrap">
              <img src="/images/2.png" alt="Artisan Welcome Kit" class="portfolio-img" />
            </div>
            <div class="portfolio-info">
              <span class="project-tag green">Custom Design</span>
              <h4 class="portfolio-name">Artisan Welcome Kit</h4>
              <p class="portfolio-materials">Hemp, Organic Cotton</p>
              <p class="portfolio-desc">Thoughtfully curated welcome packages that make lasting first impressions.</p>
            </div>
          </div>

          <div class="portfolio-card scroll-reveal">
            <div class="portfolio-img-wrap">
              <img src="/images/4.png" alt="Conference Keepsakes" class="portfolio-img" />
            </div>
            <div class="portfolio-info">
              <span class="project-tag olive">Event Gifts</span>
              <h4 class="portfolio-name">Conference Keepsakes</h4>
              <p class="portfolio-materials">Cork, Recycled Glass</p>
              <p class="portfolio-desc">Memorable conference gifts that embody the event's sustainability message.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Impact Metrics -->
    <section class="wrk-section bg-dark">
      <div class="wrk-inner">
        <div class="section-header scroll-reveal">
          <h2 class="section-title white">Our Impact in Numbers</h2>
          <p class="section-sub white-sub">Every creation makes a difference for our artists, partners, and the planet</p>
        </div>
        <div class="metrics-grid">
          <div class="metric-card scroll-reveal">
            <div class="metric-number">50+</div>
            <p class="metric-label">Projects Completed</p>
          </div>
          <div class="metric-card scroll-reveal">
            <div class="metric-number">25+</div>
            <p class="metric-label">Artists Empowered</p>
          </div>
          <div class="metric-card scroll-reveal">
            <div class="metric-number">15+</div>
            <p class="metric-label">Partner Companies</p>
          </div>
          <div class="metric-card scroll-reveal">
            <div class="metric-number">1000+</div>
            <p class="metric-label">Sustainable Gifts Created</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="wrk-section bg-white">
      <div class="wrk-inner">
        <h2 class="section-title scroll-reveal">What Our Partners Say</h2>
        <div class="testimonials-grid">

          <div class="testimonial-card scroll-reveal">
            <p class="testimonial-quote">"Working with Ecorazón transformed how we approach corporate gifting. The artistic quality and sustainability message perfectly aligned with our values, and knowing we're supporting talented artists makes it even more meaningful."</p>
            <div class="testimonial-author">
              <div class="author-avatar">JS</div>
              <div>
                <p class="author-name">Jane Smith</p>
                <p class="author-role">CSR Director, Tech Company</p>
              </div>
            </div>
          </div>

          <div class="testimonial-card scroll-reveal">
            <p class="testimonial-quote">"The attention to detail and storytelling in every piece is remarkable. Our clients are always impressed with the quality and the story behind each gift. Ecorazón has become our go-to partner for meaningful corporate gifts."</p>
            <div class="testimonial-author">
              <div class="author-avatar">MR</div>
              <div>
                <p class="author-name">Michael Rodriguez</p>
                <p class="author-role">Marketing Director, Sustainability Firm</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="wrk-section bg-white">
      <div class="wrk-inner cta-inner">
        <h2 class="section-title scroll-reveal">Ready to Start Your Project?</h2>
        <p class="section-sub scroll-reveal">Let's create something beautiful and meaningful together. Every project is a new opportunity to make a positive impact.</p>
        <div class="cta-buttons scroll-reveal">
          <a href="/get-in-touch" class="wrk-cta primary">Contact Us to Start Your Project</a>
          <a href="/event" class="wrk-cta ghost">Learn More About Our Services →</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  .works-page {
    padding-top: 72px;
  }

  /* ─── HERO ─── */
  .works-hero {
    background: url('/images/orange.png') center center / cover no-repeat;
    padding: 6rem clamp(2rem, 8vw, 7rem);
    min-height: 260px;
    display: flex;
    align-items: flex-end;
  }

  .works-hero-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: #000000;
    margin: 0 0 0.5rem 0;
    line-height: 1.1;
  }

  .works-hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: #000000;
    opacity: 0.7;
    margin: 0;
    max-width: 560px;
  }

  /* ─── HERO ANIMATION ─── */
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in       { animation: fadeInDown 0.8s ease-out 0.2s both; }
  .animate-fade-in-delay { animation: fadeInDown 0.8s ease-out 0.4s both; }

  /* ─── SECTIONS ─── */
  .wrk-section {
    padding: 5rem clamp(2rem, 6vw, 6rem);
  }

  .bg-white { background: #ffffff; }
  .bg-warm  { background: #f7f5f0; }
  .bg-dark  { background: #95BD8D; }

  .wrk-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ─── TYPOGRAPHY ─── */
  .section-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    color: #000000;
    margin: 0 0 1rem 0;
    line-height: 1.15;
  }

  .section-title.white { color: #ffffff; }

  .section-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #000000;
    opacity: 0.6;
    margin: 0 0 3rem 0;
    max-width: 560px;
    line-height: 1.7;
  }

  .section-sub.white-sub {
    color: #ffffff;
    opacity: 0.85;
  }

  .intro-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    color: #000000;
    opacity: 0.65;
    line-height: 1.9;
    max-width: 760px;
    margin: 0;
  }

  /* ─── FEATURED PROJECTS ─── */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.08);
    background: #ffffff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .project-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-4px);
  }

  .project-img-wrap {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #f0f4f0;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-img {
    transform: scale(1.03);
  }

  .project-info {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .project-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: #ffffff;
    padding: 0.2rem 0.65rem;
  }

  .project-tag.green  { background: #95BD8D; }
  .project-tag.olive  { background: #6b8f76; }
  .project-tag.brown  { background: #a07850; }

  .project-year {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    color: #000000;
    opacity: 0.4;
  }

  .project-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: #000000;
    margin: 0 0 0.4rem 0;
  }

  .project-materials {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    color: #000000;
    opacity: 0.45;
    margin: 0 0 0.75rem 0;
  }

  .project-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #000000;
    opacity: 0.6;
    line-height: 1.7;
    margin: 0 0 1.25rem 0;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: #000000;
    opacity: 0.55;
    border: 1px solid rgba(0,0,0,0.15);
    padding: 0.2rem 0.6rem;
  }

  /* ─── PORTFOLIO GRID ─── */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .portfolio-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.08);
    background: #ffffff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .portfolio-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-4px);
  }

  .portfolio-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #f0f4f0;
  }

  .portfolio-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .portfolio-card:hover .portfolio-img {
    transform: scale(1.03);
  }

  .portfolio-info {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .portfolio-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #000000;
    margin: 0.25rem 0 0 0;
  }

  .portfolio-materials {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: #000000;
    opacity: 0.4;
    margin: 0;
  }

  .portfolio-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    color: #000000;
    opacity: 0.6;
    line-height: 1.6;
    margin: 0;
  }

  /* ─── METRICS ─── */
  .section-header {
    margin-bottom: 3rem;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .metric-card {
    padding: 2rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.1);
    text-align: center;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .metric-card:hover {
    background: rgba(255,255,255,0.2);
    transform: translateY(-4px);
  }

  .metric-number {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 2.5rem;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .metric-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #ffffff;
    opacity: 0.85;
    margin: 0;
  }

  /* ─── TESTIMONIALS ─── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .testimonial-card {
    border: 1px solid rgba(0,0,0,0.08);
    padding: 2rem;
    background: #f7f5f0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .testimonial-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
    transform: translateY(-4px);
  }

  .testimonial-quote {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: #000000;
    opacity: 0.7;
    line-height: 1.8;
    margin: 0;
    font-style: italic;
    flex: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 2.5rem;
    height: 2.5rem;
    background: #95BD8D;
    color: #ffffff;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    color: #000000;
    margin: 0;
  }

  .author-role {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: #000000;
    opacity: 0.45;
    margin: 0;
  }

  /* ─── CTA ─── */
  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .cta-buttons {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .wrk-cta {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.65rem 1.5rem;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .wrk-cta.primary {
    background: #95BD8D;
    color: #ffffff;
  }

  .wrk-cta.primary:hover {
    background: #C08EA4;
  }

  .wrk-cta.ghost {
    background: transparent;
    color: #000000;
    opacity: 0.6;
    padding: 0.65rem 0;
  }

  .wrk-cta.ghost:hover {
    opacity: 1;
  }

  /* ─── SCROLL REVEAL ─── */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .featured-grid .project-card:nth-child(1) { transition-delay: 0.1s; }
  .featured-grid .project-card:nth-child(2) { transition-delay: 0.25s; }

  .portfolio-grid .portfolio-card:nth-child(1) { transition-delay: 0.1s; }
  .portfolio-grid .portfolio-card:nth-child(2) { transition-delay: 0.25s; }
  .portfolio-grid .portfolio-card:nth-child(3) { transition-delay: 0.4s; }

  .metrics-grid .metric-card:nth-child(1) { transition-delay: 0.1s; }
  .metrics-grid .metric-card:nth-child(2) { transition-delay: 0.2s; }
  .metrics-grid .metric-card:nth-child(3) { transition-delay: 0.3s; }
  .metrics-grid .metric-card:nth-child(4) { transition-delay: 0.4s; }

  .testimonials-grid .testimonial-card:nth-child(1) { transition-delay: 0.1s; }
  .testimonials-grid .testimonial-card:nth-child(2) { transition-delay: 0.25s; }

  /* ─── MOBILE ─── */
  @media (max-width: 1024px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .featured-grid,
    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .portfolio-grid,
    .metrics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
  });
</script>