---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us - Ecorazón">
  <Header />

  <main class="about-page">

    <!-- Soft blurred orb that drifts across the page as you scroll.
         Scoped to this page only — see GSAP script at the bottom. -->
    <div class="about-parallax-bg" aria-hidden="true">
      <div class="parallax-orb"></div>
    </div>

    <!-- Hero Section -->
    <section class="about-hero">
      <h1 class="about-hero-title animate-fade-in">About<br />Ecorazón</h1>
      <p class="about-hero-sub animate-fade-in-delay">Where nature's echo meets the art with heart</p>
    </section>

    <section class="about-section layout-left bg-white">
      <div class="about-inner narrow">
        <h2 class="section-title scroll-reveal i18n-text" data-zh="自然緻語的故事">Why Ecorazón?</h2>
        <p class="section-body scroll-reveal i18n-text" data-zh="Ecorazón 是自然與藝術的心聲相遇之處。我們結合設計思維、創新科技、永續材質與人的創造力，讓同理心成為可見、可用、可賦能的力量。">
          Ecorazón is where nature's echo meets the art with heart. We bring together design thinking, innovative technology, sustainable materials, and human creativity to transform empathy into a visible, usable, and empowering force.
        </p>
      </div>
    </section>

    <!-- What does Ecorazón mean -->
    <section class="about-section layout-bigtype bg-warm">
      <div class="about-inner narrow">
        <h2 class="section-title scroll-reveal i18n-text" data-zh="名字的由來">What does Ecorazón mean?</h2>
        <p class="section-body scroll-reveal i18n-text" data-zh="Ecorazón 由「eco」與西班牙文「corazón」（心）組成，代表我們相信永續不只是責任，也應該承載人的溫度、情感，以及每個生命獨有的故事。">
          The name Ecorazón combines "eco" and "corazón," the Spanish word for "heart." It reflects our belief that sustainability should not only be responsible, but also human, emotional, and deeply connected to the stories people carry.
        </p>
      </div>
    </section>

    <!-- Value / Vision / Mission — interactive triangle of overlapping
         circles with a center "glue" logo. Hover (desktop) or tap (mobile)
         a circle to swap its text for an image and switch the text panel
         below to match. First pass — positions/sizes are a starting guess,
         easiest to tune once you see it live. -->
    <section class="about-section vmv-section bg-white">
      <div class="vmv-circles scroll-reveal">

        <!-- TODO: replace with the real center "glue" logo -->
        <div class="vmv-logo">
          <img src="/images/vmv-logo-mark.png" alt="" />
        </div>

        <button class="vmv-circle vmv-circle-value" data-key="value" aria-label="Our Value">
          <span class="vmv-circle-text">Value</span>
          <!-- TODO: replace with the real Value image -->
          <img class="vmv-circle-image" src="/images/vmv-value.png" alt="" />
        </button>

        <button class="vmv-circle vmv-circle-vision" data-key="vision" aria-label="Our Vision">
          <span class="vmv-circle-text">Vision</span>
          <!-- TODO: replace with the real Vision image -->
          <img class="vmv-circle-image" src="/images/vmv-vision.png" alt="" />
        </button>

        <button class="vmv-circle vmv-circle-mission" data-key="mission" aria-label="Our Mission">
          <span class="vmv-circle-text">Mission</span>
          <!-- TODO: replace with the real Mission image -->
          <img class="vmv-circle-image" src="/images/vmv-mission.png" alt="" />
        </button>
      </div>

      <div class="vmv-text-panels scroll-reveal">
        <div class="vmv-panel is-active" data-for="value">
          <h2 class="section-title i18n-text" data-zh="我們的價值">Our Value</h2>
          <p class="section-body i18n-text" data-zh="我們重視同理、共融、創意與永續。我們相信每一個人都擁有獨特的創造潛能，而每一次合作都能成為品牌、社群與自然之間共好循環的力量。">
            We value empathy, inclusion, creativity, and sustainability. We believe every person has unique creative potential, and every collaboration can become a force for shared good across brands, communities, and the natural world.
          </p>
        </div>

        <div class="vmv-panel" data-for="vision">
          <h2 class="section-title i18n-text" data-zh="我們的願景">Our Vision</h2>
          <p class="section-body i18n-text" data-zh="我們期待建立一個善的循環，讓同理心被轉化為有意義的體驗、負責任的產品、文化連結與共融系統。我們希望把商業、身心健康、創意與永續串連成一個有生命力的生態系統。">
            We envision a virtuous cycle of good, where empathy is translated into meaningful experiences, responsible products, cultural connections, and inclusive systems. We hope to connect business, wellbeing, creativity, and sustainability into one living ecosystem.
          </p>
        </div>

        <div class="vmv-panel" data-for="mission">
          <h2 class="section-title i18n-text" data-zh="我們的使命">Our Mission</h2>
          <p class="section-body i18n-text" data-zh="我們的使命，是透過四大服務範疇——品牌禮品設計、商務藝文策展、員工身心健康、創新永續發展——創造真正的影響力。我們結合設計、科技與永續思維，為個人、機構與社群發展具價值的體驗與解決方案。">
            Our mission is to create impact through four major service areas: Corporate Gifts, Curated MICE, Wellness Initiative, and ESG Solutions. By combining design, technology, and sustainability, we develop experiences and solutions that create value for people, organizations, and communities.
          </p>
        </div>
      </div>
    </section>

    <!-- Our Culture -->
    <section class="about-section layout-bigtype bg-warm">
      <div class="about-inner narrow">
        <h2 class="section-title scroll-reveal i18n-text" data-zh="團隊的文化">Our culture</h2>
        <p class="section-body scroll-reveal i18n-text" data-zh="我們的團隊文化建立於同理、開放與共同成長之上。我們重視 DEI——多元、公平與共融，並相信創意空間應該容納不同背景、觀點與能力的人。">
          Our culture is grounded in empathy, openness, and shared growth. We are committed to DEI—diversity, equity, and inclusion—and we believe creative spaces should welcome different backgrounds, perspectives, and abilities.
        </p>
      </div>
    </section>

    <!-- Our Team -->
    <section class="about-section layout-left bg-white">
      <div class="about-inner narrow">
        <h2 class="section-title scroll-reveal">Our Team</h2>
        <p class="section-body scroll-reveal i18n-text" data-zh="我們也重視職涯發展與實習機會，並將其視為品牌生態系的重要一環。透過為新晉人才、青年專業人士與跨領域學習者創造參與路徑，我們希望培育新一代具使命感的創作者與行動者。">
          We also value career development and internship opportunities as part of our ecosystem. By creating pathways for emerging talents, young professionals, and cross-disciplinary learners, we hope to nurture a new generation of purpose-driven creators and changemakers.
        </p>

        <!-- TODO: replace with the real team photo -->
        <div class="team-photo-placeholder scroll-reveal">
          <img src="/images/team-photo.jpg" alt="The Ecorazón team" />
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  .about-page {
    padding-top: 72px;
    position: relative; /* establishes the stacking context the orb sits behind */
  }

  /* ─── PARALLAX BACKGROUND (About page only) ─── */
  .about-parallax-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .parallax-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 70vh;
    height: 70vh;
    margin-left: -35vh;
    margin-top: -35vh;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #d9ecd4, #95BD8D 45%, #6b8f76 100%);
    filter: blur(70px);
    opacity: 0.55;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .parallax-orb { display: none; }
  }

  @media (max-width: 768px) {
    .parallax-orb {
      width: 55vh;
      height: 55vh;
      margin-left: -27.5vh;
      margin-top: -27.5vh;
      opacity: 0.4;
    }
  }

  /* ─── HERO ─── */
  .about-hero {
    position: relative;
    z-index: 1;
    background: transparent;
    min-height: 100vh;
    overflow: hidden;
  }

  /* Asymmetric placement — diagonally opposite corners, overlapping the
     orb, rather than a centered stack. Adjust the top/left/right/bottom
     percentages to taste once you see it against your actual orb size. */
  .about-hero-title {
    position: absolute;
    top: 22%;
    left: 8%;
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    color: #000000;
    margin: 0;
    line-height: 1.1;
    max-width: 480px;
  }

  .about-hero-sub {
    position: absolute;
    bottom: 18%;
    right: 8%;
    text-align: right;
    font-family: 'MaoWei', sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    color: #000000;
    opacity: 0.7;
    margin: 0;
    max-width: 320px;
  }

  /* ─── HERO ANIMATIONS ─── */
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fadeInDown 0.8s ease-out 0.2s both;
  }

  .animate-fade-in-delay {
    animation: fadeInDown 0.8s ease-out 0.4s both;
  }

  /* ─── SECTIONS ─── */
  /* position:relative + z-index:1 keeps every section's own paint above the
     fixed orb. Each section is a full viewport tall, content centered
     within it — so scrolling moves cleanly from one full-screen section
     to the next. */
  .about-section {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 5rem clamp(2rem, 6vw, 6rem);
  }

  .bg-white  { background: transparent; }
  .bg-warm   { background: transparent; }

  /* ─── VALUE / VISION / MISSION — interactive triangle of circles ─── */
  .vmv-section {
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    padding-top: 3rem;
    padding-bottom: 3rem;
    text-align: left;
  }

  .vmv-circles {
    position: relative;
    flex-shrink: 0;
    width: min(40vw, 420px);
    height: min(40vw, 420px);
  }

  .vmv-circle {
    position: absolute;
    width: 58%;
    height: 58%;
    border-radius: 50%;
    border: 2px dashed rgba(0, 0, 0, 0.25);
    background: transparent;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: border-color 0.45s ease;
  }

  .vmv-circle:hover,
  .vmv-circle.is-active {
    border-color: #87c090;
  }

  /* Triangle arrangement — top circle, two overlapping below it */
  .vmv-circle-value {
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .vmv-circle-vision {
    top: 40%;
    left: 2%;
  }

  .vmv-circle-mission {
    top: 40%;
    right: 2%;
  }

  .vmv-circle-text {
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #000000;
    transition: opacity 0.45s ease;
  }

  .vmv-circle-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  .vmv-circle:hover .vmv-circle-image,
  .vmv-circle.is-active .vmv-circle-image {
    opacity: 1;
  }

  .vmv-circle:hover .vmv-circle-text,
  .vmv-circle.is-active .vmv-circle-text {
    opacity: 0;
  }

  /* Center "glue" logo, sitting where all three circles overlap */
  .vmv-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 18%;
    height: 18%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    pointer-events: none;
  }

  .vmv-logo img {
    width: 60%;
    height: 60%;
    object-fit: contain;
  }

  /* Text panel below — all three stacked in the same spot, crossfading */
  .vmv-text-panels {
    position: relative;
    flex: 1 1 420px;
    width: 100%;
    max-width: 540px;
    min-height: 12rem;
  }

  .vmv-panel {
    position: absolute;
    inset: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
  }

  .vmv-panel.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .vmv-panel .section-title {
    text-align: left;
  }

  .vmv-panel .section-body {
    max-width: none;
  }

  /* ─── LAYOUT VARIANTS (for sections that aren't diagonal) ─── */
  /* Breaks up the otherwise-repeated "centered narrow column" pattern
     without going full-diagonal everywhere. */

  /* Off-center: the whole text block shifts to one side instead of
     sitting in the middle, with empty space on the other side. */
  .layout-left {
    justify-content: flex-start;
  }

  .layout-right {
    justify-content: flex-end;
  }

  .layout-left .about-inner,
  .layout-right .about-inner {
    margin: 0; /* let the section's justify-content position it, not auto-centering */
  }

  /* Oversized title, paragraph centered underneath — a typographic
     hierarchy shift rather than a positional one. */
  .layout-bigtype {
    padding-top: 9rem;
    padding-bottom: 9rem;
  }

  .layout-bigtype .section-title {
    font-size: clamp(2.6rem, 8vw, 6rem);
    line-height: 1.15;
    margin-bottom: 3rem;
    text-align: center;
  }

  .layout-bigtype .section-body {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .narrow {
    max-width: 760px;
  }

  /* ─── TYPOGRAPHY ─── */
  .section-title {
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    color: #000000;
    margin: 0 0 1.5rem 0;
    line-height: 1.15;
  }

  .section-body {
    font-family: 'MaoWei', sans-serif;
    font-size: 1rem;
    color: #000000;
    opacity: 0.7;
    line-height: 1.8;
    margin: 0 0 1rem 0;
  }

  /* ─── TEAM PHOTO ─── */
  .team-photo-placeholder {
    margin-top: 2.5rem;
    border-radius: 4px;
    overflow: hidden;
  }

  .team-photo-placeholder img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ─── SCROLL REVEAL ─── */
  /* Starting state matches GSAP's "from" value below, so there's no flash
     of fully-visible/default-positioned text in the moment before GSAP
     finishes loading and takes over. Once it runs, it immediately
     calculates the correct value for the current scroll position anyway. */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(70px);
    will-change: transform, opacity;
  }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    .about-section {
      padding: 3.5rem clamp(1.5rem, 6vw, 3rem);
    }

    /* Diagonal placement gets cramped on narrow screens — fall back to a
       simple stacked layout near the top of the hero instead. */
    .about-hero-title {
      position: static;
      max-width: 100%;
      margin: 0 1.5rem 1rem;
      padding-top: 6rem;
    }

    .about-hero-sub {
      position: static;
      text-align: left;
      max-width: 100%;
      margin: 0 1.5rem;
    }

    /* Side-by-side becomes stacked on a narrow screen */
    .vmv-section {
      flex-direction: column;
      text-align: center;
    }

    /* Triangle of overlapping circles gets cramped on a narrow screen —
       stack the three circles vertically instead, still with the center
       logo, just smaller and simpler. */
    .vmv-circles {
      width: min(78vw, 290px);
      height: min(78vw, 290px);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .vmv-circle-text {
    font-size: 0.95rem; /* slightly smaller text fits the smaller circles better */
    }

    .vmv-text-panels {
    flex: 0 0 auto;      
    width: 100%;
    max-width: 100%;
    min-height: 16rem;
    }

    .vmv-panel .section-title {
      text-align: center;
    }

    .layout-bigtype {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    .layout-bigtype .section-body {
      max-width: 100%;
    }
  }
</style>

<!-- GSAP (About page only) — drives the parallax orb's path across the page -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>

<script>
  // ─── VALUE / VISION / MISSION TRIANGLE (hover on desktop, tap on mobile) ───
  // One function drives both the circle's text→image swap and which text
  // panel below is showing — same trigger for both, just as described:
  // hover fires it on devices that support hover, click/tap fires it on
  // everything (including desktop, as a harmless extra way to trigger it).
  document.addEventListener('DOMContentLoaded', () => {
    const circles = document.querySelectorAll('.vmv-circle');
    const panels = document.querySelectorAll('.vmv-panel');
    if (!circles.length || !panels.length) return;

    function setActive(key: string) {
      circles.forEach((c) => c.classList.toggle('is-active', c.getAttribute('data-key') === key));
      panels.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-for') === key));
    }

    circles.forEach((circle) => {
      const key = circle.getAttribute('data-key');
      if (!key) return;
      circle.addEventListener('mouseenter', () => setActive(key));
      circle.addEventListener('click', () => setActive(key));
    });
  });

  // ─── SCROLL-SCRUBBED TEXT REVEAL (GSAP ScrollTrigger) ───
  // Each .scroll-reveal element is driven by ONE timeline covering its
  // entire pass through the screen (bottom edge → center → top edge):
  //   - first half: fades/slides in as it approaches center
  //   - second half: fades/slides out and up as it leaves center
  // Using a single timeline (rather than two separate triggers with
  // adjacent ranges) guarantees there's no seam/jump where they meet —
  // that boundary mismatch was the likely cause of the glitch on entry.
  document.addEventListener('DOMContentLoaded', () => {
    const w = window as any;
    if (!w.gsap || !w.ScrollTrigger) return; // CDN failed to load — fail quietly, no broken page

    w.gsap.registerPlugin(w.ScrollTrigger);

    document.querySelectorAll('.scroll-reveal').forEach((el) => {
      w.gsap.timeline({
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          end: 'top -10%',
          scrub: true,
        },
      })
        .fromTo(el, { opacity: 0, y: 70 }, { opacity: 1, y: 0, ease: 'none', duration: 1 })
        .to(el, { opacity: 0, y: -70, ease: 'none', duration: 1 });
    });
  });

  // ─── PARALLAX ORB (GSAP ScrollTrigger, About page only) ───
  // The orb drifts through a handful of waypoints across the full height of
  // the page. `scrub: true` ties its progress directly to scroll position
  // (not time), so it moves exactly as fast/slow as you scroll — no
  // independent animation playing on its own. It starts centered in the
  // hero (set in CSS) and the chain below moves it on from there.
  document.addEventListener('DOMContentLoaded', () => {
    const w = window as any;
    if (!w.gsap || !w.ScrollTrigger) return;

    w.gsap.registerPlugin(w.ScrollTrigger);

    w.gsap.timeline({
      scrollTrigger: {
        trigger: '.about-page',
        start: 'top top',
        end: 'bottom bottom',
        scrub: true,
      },
    })
      .to('.parallax-orb', { top: '35%', left: '15%', scale: 1.25, ease: 'none' })
      .to('.parallax-orb', { top: '60%', left: '70%', scale: 0.85, ease: 'none' })
      .to('.parallax-orb', { top: '85%', left: '30%', scale: 1.1, ease: 'none' });
  });
</script>