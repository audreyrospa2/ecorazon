---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us - Ecorazón">
  <Header />
  
  <main class="about-page">

    <!-- Hero Section -->
    <section class="about-hero">
      <div class="about-hero-content">
        <h1 class="about-hero-title animate-fade-in">About Ecorazón</h1>
        <p class="about-hero-sub animate-fade-in-delay">Where nature's echo meets the art with heart</p>
      </div>
    </section>

    <!-- Who We Are Section -->
    <section class="about-section bg-white">
      <div class="about-inner two-col">
        <div class="who-we-are-text scroll-reveal">
          <h2 class="section-title">Who We Are</h2>
          <p class="section-body">
            Ecorazón partners with talented artists with special needs to create premium, custom-designed products for businesses. We specialize in sustainable corporate gifting that delivers social impact alongside quality craftsmanship.
          </p>
          
          <div class="feature-list">
            <div class="feature-item scroll-reveal">
              <div class="feature-icon">✨</div>
              <div>
                <h3 class="feature-title">Social Impact Through Art</h3>
                <p class="feature-body">Support talented artists with special needs while enhancing your corporate gifting program. Every purchase creates meaningful employment opportunities.</p>
              </div>
            </div>
            
            <div class="feature-item scroll-reveal">
              <div class="feature-icon">🌱</div>
              <div>
                <h3 class="feature-title">Sustainable & Eco-Friendly</h3>
                <p class="feature-body">All products use environmentally responsible materials and production methods, helping your brand reduce its environmental footprint.</p>
              </div>
            </div>
            
            <div class="feature-item scroll-reveal">
              <div class="feature-icon">⏰</div>
              <div>
                <h3 class="feature-title">Quality That Lasts</h3>
                <p class="feature-body">Durable, thoughtfully designed gifts that recipients will value and remember, ensuring your brand makes a lasting impression.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="who-we-are-image scroll-reveal">
          <img 
            src="/images/green.jpg" 
            alt="Ecorazón showcase" 
            class="side-image"
          />
        </div>
      </div>
    </section>

    <!-- Our Story Section -->
    <section class="about-section bg-warm">
      <div class="about-inner narrow">
        <h2 class="section-title scroll-reveal">Our Story</h2>
        <div class="story-card scroll-reveal">
          <p class="section-body">
            Ecorazón was born from a simple belief: every individual is a masterpiece of nature.
          </p>
          <p class="section-body">
            The name Ecorazón combines "Eco," representing ecology and sustainability, with the Spanish word "Corazón" (heart). It also evokes the idea of an echo — the resonance of nature's voice within the human spirit.
          </p>
        </div>
      </div>
    </section>

    <!-- Mission & Vision Section -->
    <section class="about-section bg-white">
      <div class="about-inner two-col-equal">
        <div class="mv-card mission scroll-reveal">
          <h2 class="mv-title">Our Mission</h2>
          <p class="mv-body">
            To listen deeply to the voice of nature, capture its inspiration, and transform these echoes into heartfelt, sustainable creations.
          </p>
        </div>
        
        <div class="mv-card vision scroll-reveal">
          <h2 class="mv-title">Our Vision</h2>
          <p class="mv-body">
            To inspire more people to see themselves as miracles of nature and cherish the purest beauty of this planet we call home.
          </p>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<style is:global>
  .about-page {
    padding-top: 72px;
  }

  /* ─── HERO ─── */
  .about-hero {
    background: url('/images/gradient-bg-1.png') center center / cover no-repeat;
    padding: 6rem clamp(2rem, 8vw, 7rem);
    min-height: 260px;
    display: flex;
    align-items: flex-end;
  }

  .about-hero-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: #000000;
    margin: 0 0 0.5rem 0;
    line-height: 1.1;
  }

  .about-hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: #000000;
    opacity: 0.7;
    margin: 0;
    max-width: 500px;
  }

  /* ─── HERO ANIMATIONS ─── */
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fadeInDown 0.8s ease-out 0.2s both;
  }

  .animate-fade-in-delay {
    animation: fadeInDown 0.8s ease-out 0.4s both;
  }

  /* ─── SECTIONS ─── */
  .about-section {
    padding: 5rem clamp(2rem, 6vw, 6rem);
  }

  .bg-white  { background: #ffffff; }
  .bg-warm   { background: #f7f5f0; }

  .about-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .two-col-equal {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .narrow {
    max-width: 760px;
  }

  /* ─── TYPOGRAPHY ─── */
  .section-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    color: #000000;
    margin: 0 0 1.5rem 0;
    line-height: 1.15;
  }

  .section-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #000000;
    opacity: 0.65;
    line-height: 1.8;
    margin: 0 0 1rem 0;
  }

  /* ─── FEATURE LIST ─── */
  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 2rem;
  }

  .feature-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem;
    border: 1px solid transparent;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
    cursor: default;
  }

  .feature-item:hover {
    background: rgba(149, 189, 141, 0.08);
    border-color: rgba(149, 189, 141, 0.3);
    transform: translateX(6px);
  }

  .feature-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .feature-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #000000;
    margin: 0 0 0.3rem 0;
  }

  .feature-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #000000;
    opacity: 0.6;
    line-height: 1.6;
    margin: 0;
  }

  /* ─── SIDE IMAGE ─── */
  .who-we-are-image {
    transition: box-shadow 0.3s ease;
  }

  .who-we-are-image:hover {
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }

  .side-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  /* ─── STORY CARD ─── */
  .story-card {
    border: 1px solid rgba(0,0,0,0.08);
    padding: 2.5rem;
    background: #ffffff;
    transition: box-shadow 0.25s ease;
  }

  .story-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
  }

  /* ─── MISSION / VISION ─── */
  .mv-card {
    padding: 2.5rem;
    border: 1px solid rgba(0,0,0,0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    cursor: default;
  }

  .mv-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-4px);
  }

  .mission { background: #95BD8D; }
  .vision  { background: #6b8f76; }

  .mv-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: #ffffff;
    margin: 0 0 1rem 0;
  }

  .mv-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #ffffff;
    opacity: 0.9;
    line-height: 1.8;
    margin: 0;
  }

  /* ─── SCROLL REVEAL ─── */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* stagger feature items */
  .feature-item:nth-child(1) { transition-delay: 0.1s; }
  .feature-item:nth-child(2) { transition-delay: 0.25s; }
  .feature-item:nth-child(3) { transition-delay: 0.4s; }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    .two-col,
    .two-col-equal {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
  });
</script>