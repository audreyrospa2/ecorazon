---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Ecorazón - Where Nature's Echo Meets the Art with Heart">
  <Header />

  <main>

    <!-- Hero Section -->
    <section class="hero-section">
      <img src="/images/grid.png" alt="" class="hero-grid" aria-hidden="true" loading="eager" />
      <div class="hero-content">
        <h1 class="hero-tagline">
          <span>HEARTFELT STORIES</span>
          <span>SUSTAINABLE FUTURE</span>
        </h1>
        <p class="hero-subtitle-zh" lang="zh-Hant">以故事連結人心 · 以永續策展未來</p>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="stat-number-wrap">
              <span class="stat-number" data-target="1500">0</span>
              <span class="stat-plus">+</span>
            </div>
            <p class="stat-label">Audience Engaged</p>
          </div>
          <div class="hero-stat">
            <div class="stat-number-wrap">
              <span class="stat-number" data-target="100">0</span>
              <span class="stat-plus">+</span>
            </div>
            <p class="stat-label">Brands Collaborated</p>
          </div>
          <div class="hero-stat">
            <div class="stat-number-wrap">
              <span class="stat-number" data-target="300">0</span>
              <span class="stat-plus">+</span>
            </div>
            <p class="stat-label">Merchandise Ideas</p>
          </div>
        </div>
      </div>
      <img src="/images/hero-element.png" alt="" class="hero-element" loading="eager" />
    </section>

    <!-- Logo Marquee Bar -->
    <div class="logo-bar">
      <div class="logo-track">
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/bnw-logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Cathay-Pacific-english-Logo-Vector.svg-.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/China-Construction-Bank-Corporation-Logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Clockenflap_logo.svg.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Cyberport_Logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/erb-logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/eyelevel-logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/genki-logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Hong_Kong_Monetary_Authority_logo.svg.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Hong-Kong-Exchanges-and-Clearing-Ltd-Logo.svg" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Hongkong_Electric_(logo).png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Logo_FWD.svg.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/manor-hill.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Manulife_logo.svg.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/onesoho.jpg" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/SCMP_logo.svg.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/taihing-logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Urban_Renewal_Authority.svg.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Wastsonwine_logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/Watsons_logotype.svg.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/wsd_logo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/香港存款保障委員會-logo.png" alt="Brand" /></div>
      </div>
    </div>

    <!-- About Section -->
    <section class="py-80 bg-white">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-color-cork-brown mb-8 tracking-wide about-title">
          ABOUT US
        </h2>
        <p class="text-lg text-gray-700 leading-relaxed about-text i18n-text" data-zh="我們以設計思維和創新科技推動善的循環，融合人工智能與永續材質，讓同理心成為可見、可用、可賦能的力量，實踐於企業文化、藝術教育、身心健康與永續發展之中。">
          We drive a virtuous C.Y.C.L.E. of Good through design thinking and innovative technology, integrating AI and sustainable materials to turn empathy into a visible, practical, and empowering force across corporate culture, arts education, wellbeing, and sustainable development.
        </p>
        <a href="/about" class="btn-outline about-text i18n-text" data-zh="認識我們">View our Stories</a>
      </div>
    </section>
 
    <!-- C.Y.C.L.E. of Good → Our Services Section -->
    <!-- One continuous background: solid green behind the C.Y.C.L.E. heading,
         fading down into the light off-white grey behind the Services cards. -->
    <section class="cycle-to-services">
 
      <div class="cycle-block text-center">
        <div class="max-w-4xl mx-auto px-6">
          <h2 class="cycle-title">
            Creativity x Strategy x Experience x Community
          </h2>
          <p class="cycle-text i18n-text" data-zh="C.Y.C.L.E. of Good 是自然緻語的方法論與共創生態圈，透過栽培可能、蘊育洞見、開創實踐、共創影響與賦能轉變，連結創意、策略、體驗與社群，推動善的循環。">
            C.Y.C.L.E. of Good is ECORAZÓN's methodology and collaborative ecosystem, connecting creativity, strategy, experience, and community through five stages of positive change.
          </p>
          <a href="/about#cycle-of-good" class="btn-outline-light cycle-text i18n-text" data-zh="探索 C.Y.C.L.E. of Good">Explore C.Y.C.L.E. of Good</a>
        </div>
      </div>
 
      <div class="services-block">
        <div class="max-w-6xl mx-auto px-6">
          <h2 class="services-title">Our Services</h2>
 
          <div class="service-row">
            <div class="service-num">#1</div>
            <div class="service-body">
              <h3 class="service-title-line">Corporate Gifts｜品牌禮品設計</h3>
              <p class="service-subtitle">Ecorazón Atelier｜緻語藝廊</p>
              <p class="service-desc i18n-text" data-zh="與展能藝術家合作，以永續材質策劃品牌禮品與限量作品，打造具「藝術 × 共融 × 永續」的獨家創新永續企業禮品。">
                We create branded gifts and limited-edition pieces with disability artists and sustainable materials, crafting distinctive corporate gifts shaped by art, inclusion, and sustainability.
              </p>
              <a href="/product" class="btn-outline i18n-text" data-zh="更多產品">View our Products</a>
            </div>
            <!-- TODO: replace with a real product/gift image -->
            <div class="service-float-wrap" data-direction="top-left">
              <img src="/images/graphic-1.png" alt="" class="service-float" />
            </div>
          </div>
 
          <div class="service-row">
            <div class="service-num">#2</div>
            <div class="service-body">
              <h3 class="service-title-line">Curated MICE｜商務藝文策展</h3>
              <p class="service-subtitle">Ecorazón StoryLab｜自然緻語實驗空間</p>
              <p class="service-desc i18n-text" data-zh="透過策展敘事、體驗設計與創新內容，打造具「故事 × 參與 × 共鳴」的商務藝文體驗，讓更多人看見品牌理念、文化歷史、社會議題與共融價值。">
                Through curatorial storytelling, experiential design, and innovative content, we create business and cultural experiences shaped by story, participation, and resonance.
              </p>
              <a href="/event" class="btn-outline i18n-text" data-zh="過往活動">View our Events</a>
            </div>
            <!-- TODO: replace with a real event/MICE image -->
            <div class="service-float-wrap" data-direction="top-right">
              <img src="/images/graphic-2.png" alt="" class="service-float" />
            </div>
          </div>
 
          <div class="service-row">
            <div class="service-num">#3</div>
            <div class="service-body">
              <h3 class="service-title-line">Wellness Initiative｜員工身心健康</h3>
              <p class="service-subtitle">Ecorazón Wellbeing Movement｜身心共好行動</p>
              <p class="service-desc i18n-text" data-zh="透過身心平衡體驗、度假式團隊活動與專業支援，策劃具「療癒 × 連結 × 重整」的身心健康方案，讓每個人都能真正放鬆、整合與重新出發。">
                We design wellbeing programs through balance-focused experiences, retreat-style team activities, and professional support, creating space for people to unwind, reset, and begin again.
              </p>
              <a href="/programme" class="btn-outline i18n-text" data-zh="更多企劃">View our Programmes</a>
            </div>
            <!-- TODO: replace with a real wellness image -->
            <div class="service-float-wrap" data-direction="bottom-left">
              <img src="/images/graphic-3.png" alt="" class="service-float" />
            </div>
          </div>
 
          <div class="service-row">
            <div class="service-num">#4</div>
            <div class="service-body">
              <h3 class="service-title-line">ESG Solutions｜創新永續發展</h3>
              <p class="service-subtitle">Ecorazón Think Tank｜永續共好智庫</p>
              <p class="service-desc i18n-text" data-zh="以研究洞察、對話設計與策略共創，連結有意義的工作坊、義工機會與社會參與項目，從小型 CSR 行動到 ESG 發展路線，打造可持續擴展的共好方案。">
                Using research insight, dialogue design, and co-created strategy, we connect workshops, volunteer opportunities, and social engagement—from small CSR actions to broader ESG roadmaps.
              </p>
              <a href="/resources" class="btn-outline i18n-text" data-zh="更多資源">View our Resources</a>
            </div>
            <!-- TODO: replace with a real ESG/resources image -->
            <div class="service-float-wrap" data-direction="bottom-right">
              <img src="/images/graphic-4.png" alt="" class="service-float" />
            </div>
          </div>
 
        </div>
      </div>
 
    </section>
 
    <!-- CTA Section -->
    <section class="cta-section text-center">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 tracking-wide parallax-text">
          READY TO CREATE SOMETHING MEANINGFUL?
        </h2>
        <p class="text-lg mb-8 leading-relaxed parallax-text">
          Let's co-create gifts and experiences that inspire, empower, and sustain.
        </p>
        <a href="/get-in-touch" class="cta-btn">Get in Touch</a>
      </div>
    </section>
 
  </main>
 
  <Footer />
</Layout>
 
<style is:global>
 
  html { scroll-behavior: smooth; }
 
  /* ─── HERO ─── */
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 560px;
    overflow: hidden;
    background: url('/images/gradient-bg-1.png') center center / cover no-repeat;
    display: flex;
    align-items: flex-start;
    padding: 10% 0 0 clamp(2rem, 6vw, 6rem);
  }
 
  .hero-grid {
    position: absolute;
    bottom: -15%;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    height: 80%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.7;
  }
 
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 50%;
  }
 
  .hero-tagline {
    display: flex;
    flex-direction: column;
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 3.8rem);
    line-height: 1.1;
    color: #000000;
    margin: 0 0 0.75rem 0;
    letter-spacing: 0;
    white-space: nowrap;
  }
 
  .hero-tagline span {
    display: block;
    white-space: nowrap;
  }
 
  .hero-subtitle-zh {
    font-family: 'MaoWei', serif;
    font-size: clamp(0.85rem, 1.2vw, 1.1rem);
    font-weight: 400;
    color: #000000;
    letter-spacing: 0.04em;
    margin: 0;
  }
 
  .hero-stats {
    display: flex;
    gap: 2.5rem;
    margin-top: 2rem;
  }
 
  .hero-stat {
    display: flex;
    flex-direction: column;
  }
 
  .stat-number-wrap {
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
 
  .stat-number {
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    color: #275D2F;
    line-height: 1;
  }
 
  .stat-plus {
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    color: #95BD8D;
    line-height: 1;
    display: inline;
  }
 
  .stat-label {
    font-family: 'MaoWei', sans-serif;
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    font-weight: 400;
    color: #000000;
    margin-top: 0.25rem;
    opacity: 0.7;
  }
 
  .hero-element {
    position: absolute;
    right: -10%;
    top: -7%;
    width: 450%;
    max-width: none;
    height: 110%;
    object-fit: contain;
    object-position: top right;
    z-index: 1;
    pointer-events: none;
  }
 
  /* ─── HERO ENTRANCE ANIMATIONS ─── */
  .hero-tagline,
  .hero-subtitle-zh,
  .hero-stats {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
 
  .hero-element {
    opacity: 0;
    transform: translateX(80px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }
 
  .hero-tagline.hero-visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.1s;
  }
 
  .hero-subtitle-zh.hero-visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.3s;
  }
 
  .hero-stats.hero-visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.5s;
  }
 
  @keyframes float {
  0%   { transform: translateY(0px); }
  50%  { transform: translateY(-18px); }
  100% { transform: translateY(0px); }
  }
 
  .hero-element.hero-visible {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.2s;
    animation: float 4s ease-in-out infinite;
  }
 
  /* ─── LOGO BAR ─── */
  .logo-bar {
    width: 100%;
    overflow: hidden;
    background: #ffffff;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding: 1.5rem 0;
    position: relative;
    z-index: 3;
  }
 
  .logo-track {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: max-content;
    animation: marquee 30s linear infinite;
  }
 
  .logo-bar:hover .logo-track {
    animation-play-state: paused;
  }
 
  .logo-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
 
  .logo-item img {
    height: 36px;
    width: auto;
    filter: grayscale(100%) opacity(0.5);
    transition: filter 0.3s ease;
    pointer-events: none;
  }
 
  .logo-bar:hover .logo-item img {
    filter: grayscale(0%) opacity(1);
  }
 
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
 
  /* ─── GENERIC OUTLINE BUTTONS ─── */
  .btn-outline {
    display: inline-block;
    margin-top: 1.5rem;
    background: transparent;
    color: #87c090;
    border: 2px solid #87c090;
    padding: 0.65rem 1.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
 
  .btn-outline:hover {
    background: #87c090;
    color: #ffffff;
    transform: translateY(-3px);
  }
 
  .btn-outline-light {
    display: inline-block;
    margin-top: 1.5rem;
    background: transparent;
    color: #ffffff;
    border: 2px solid #ffffff;
    padding: 0.65rem 1.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, color 1.1s ease, border-color 1.1s ease, transform 0.2s ease;
  }
 
  .btn-outline-light:hover {
    background: #ffffff;
    color: #275D2F;
    transform: translateY(-3px);
  }
 
  /* ─── C.Y.C.L.E. OF GOOD → OUR SERVICES (continuous background) ─── */
  /* One shared background for both blocks. Starts solid green; once the
     section's top edge scrolls up to meet the fixed header, JS adds
     .bg-grey and this color smoothly transitions to the light off-white
     grey (see the script at the bottom of the page for the trigger logic). */
  .cycle-to-services {
    background-color: #87c090;
    transition: background-color 1.1s ease;
  }
 
  .cycle-to-services.bg-grey {
    background-color: #F7F6F3;
  }
 
  .cycle-block {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 0;
    color: #ffffff;
    transition: color 1.1s ease;
  }
 
  /* Once the background turns grey, the C.Y.C.L.E. text/button switch to
     green so they stay readable against the light background. */
  .cycle-to-services.bg-grey .cycle-block {
    color: #275D2F;
  }
 
  .cycle-to-services.bg-grey .btn-outline-light {
    color: #275D2F;
    border-color: #275D2F;
  }
 
  .cycle-to-services.bg-grey .btn-outline-light:hover {
    background: #275D2F;
    color: #ffffff;
  }
 
  .cycle-title {
    font-family: 'MaoWei', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }
 
  .cycle-text {
    font-size: 1.1rem;
    line-height: 1.7;
    opacity: 0.95;
  }
 
  /* ─── OUR SERVICES ─── */
  .services-block {
    padding: 5rem 0 6rem;
  }
 
  .services-title {
    font-family: 'MaoWei', sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 700;
    color: #275D2F;
    text-align: center;
    margin-bottom: 3.5rem;
    letter-spacing: 0.02em;
  }
 
  .service-row {
    position: relative;
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 2rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
 
  .service-row.visible {
    opacity: 1;
    transform: translateY(0);
  }
 
  .service-row:nth-of-type(1).visible { transition-delay: 0.05s; }
  .service-row:nth-of-type(2).visible { transition-delay: 0.15s; }
  .service-row:nth-of-type(3).visible { transition-delay: 0.25s; }
  .service-row:nth-of-type(4).visible { transition-delay: 0.35s; }
 
  .service-num {
    font-family: 'MaoWei', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #95BD8D;
    line-height: 1;
  }
 
  .service-title-line {
    font-family: 'MaoWei', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #275D2F;
    margin-bottom: 0.25rem;
  }
 
  .service-subtitle {
    font-size: 0.95rem;
    font-weight: 500;
    color: #87c090;
    margin-bottom: 1rem;
  }
 
  .service-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: #4b4b4b;
    max-width: 60ch;
  }
 
  /* ─── FLOATING SERVICE ELEMENTS ─── */
  /* Each card's image starts off-screen in its own corner, flies into place
     when the row scrolls into view, then bobs gently up and down forever.
     Anchored to the vertical center of the row (not the top corner) so it
     reads as part of the card rather than sitting on the divider line. */
  .service-float-wrap {
    position: absolute;
    top: 50%;
    right: 5%;
    width: 200px;
    height: 200px;
    margin-top: -100px; /* half of height, for true vertical centering */
    opacity: 0;
    pointer-events: none;
    transition: transform 1s cubic-bezier(0.22, 1, 0.36, 1), opacity 1s ease;
  }
 
  .service-float-wrap[data-direction="top-left"]     { transform: translate(-260px, -160px) rotate(-10deg); }
  .service-float-wrap[data-direction="top-right"]    { transform: translate(260px, -160px) rotate(10deg); }
  .service-float-wrap[data-direction="bottom-left"]  { transform: translate(-260px, 160px) rotate(-10deg); }
  .service-float-wrap[data-direction="bottom-right"] { transform: translate(260px, 160px) rotate(10deg); }
 
  .service-row.visible .service-float-wrap {
    opacity: 1;
    transform: translate(0, 0) rotate(0deg);
  }
 
  .service-float {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 20px 24px rgba(39, 93, 47, 0.18));
    animation: serviceBob 3.6s ease-in-out infinite;
    animation-play-state: paused;
  }
 
  .service-row.visible .service-float {
    animation-play-state: running;
  }
 
  @keyframes serviceBob {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-14px); }
  }
 
  /* Smaller screens still get the image, just scaled and tucked in further */
  @media (max-width: 1100px) {
    .service-float-wrap {
      width: 150px;
      height: 150px;
      margin-top: -75px;
      right: 1%;
    }
  }
 
  @media (max-width: 768px) {
    /* On mobile the row collapses to one column, so these become normal
       inline elements (not absolutely positioned floats) — centered above
       the card text, smaller, with a simple straight-up entrance instead
       of the big diagonal slide (which would cause horizontal overflow
       on a narrow screen). Same image files, just repositioned. */
    .service-float-wrap {
      position: relative;
      top: auto;
      right: auto;
      margin: 0 auto 1rem;
      width: 170px;
      height: 170px;
      order: -1; /* show above the title/number rather than below the text */
    }
 
    .service-float-wrap[data-direction="top-left"],
    .service-float-wrap[data-direction="top-right"],
    .service-float-wrap[data-direction="bottom-left"],
    .service-float-wrap[data-direction="bottom-right"] {
      transform: translateY(30px);
    }
 
    .service-row.visible .service-float-wrap {
      transform: translateY(0);
    }
 
    .service-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.5rem;
    }
 
    .service-body {
      text-align: center;
    }
  }
 
  /* ─── CTA SECTION ─── */
  .cta-section {
    padding: 15rem 0;
    background: linear-gradient(-45deg, #7ACC86, #CE508F, #8AF3FF, #EB9C2E);
    background-size: 400% 400%;
    animation: gradientShift 8s ease infinite;
    color: #ffffff;
  }
 
  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
 
  .cta-btn {
    display: inline-block;
    background: #ffffff;
    color: #000000;
    padding: 0.75rem 2rem;
    border-radius: 0px;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
 
  .cta-btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
 
  /* ─── SCROLL ANIMATIONS ─── */
  .about-title, .about-text, .cycle-title, .cycle-text {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
 
  .about-title.visible  { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .about-text.visible   { opacity: 1; transform: translateY(0); transition-delay: 0.3s; }
  .cycle-title.visible  { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .cycle-text.visible   { opacity: 1; transform: translateY(0); transition-delay: 0.3s; }
 
  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    .hero-section {
      align-items: flex-start;
      padding: 5rem 1.5rem 0;
      height: auto;
      min-height: 100svh;
      flex-direction: column;
    }
 
    .hero-content {
      max-width: 100%;
      order: 1;
    }
 
    .hero-tagline {
      font-size: clamp(1.4rem, 6vw, 1.8rem);
      white-space: normal;
    }
 
    .hero-element {
      position: relative;
      right: unset;
      top: unset;
      width: 130vw;
      height: auto;
      margin: 4rem -50vw 0rem -30vw;
      display: block;
      order: 2;
      z-index: 2;
      /* keep animation transform reset intact on mobile */
      transform: translateX(80px);
    }
 
    .hero-element.hero-visible {
    transform: translateX(0);
    animation: float 4s ease-in-out infinite;
    }
 
    .hero-grid { opacity: 0.3; }
 
    .hero-stats {
      margin-top: 0.75rem;
      gap: 1rem;
    }
  }
 
</style>
 
<script>
  // ─── SCROLL REVEAL (text blocks) ───
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.2, rootMargin: '0px 0px -50px 0px' });
 
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.about-title, .about-text, .cycle-title, .cycle-text, .service-row')
      .forEach(el => observer.observe(el));
  });
 
  // ─── CYCLE → SERVICES BACKGROUND TRIGGER ───
  // The shared background starts green. It fades to grey the moment the
  // "Our Services" title reaches the vertical center of the screen —
  // not tied to the header at all, just where that title sits relative to
  // the middle of the viewport. .bg-grey on the shared section triggers
  // the CSS transition defined on .cycle-to-services.
  document.addEventListener('DOMContentLoaded', () => {
    const sharedSection = document.querySelector('.cycle-to-services');
    const servicesTitle = document.querySelector('.services-title');
    if (!sharedSection || !servicesTitle) return;
 
    function updateBg() {
      const rect = servicesTitle!.getBoundingClientRect();
      const elCenter = rect.top + rect.height / 2;
      const viewportCenter = window.innerHeight / 2;
      sharedSection!.classList.toggle('bg-grey', elCenter <= viewportCenter);
    }
 
    updateBg();
    window.addEventListener('scroll', () => requestAnimationFrame(updateBg), { passive: true });
    window.addEventListener('resize', updateBg);
  });
 
  // ─── HERO ENTRANCE ───
  document.addEventListener('DOMContentLoaded', () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        document.querySelectorAll('.hero-tagline, .hero-subtitle-zh, .hero-stats, .hero-element')
          .forEach(el => el.classList.add('hero-visible'));
      });
    });
  });
 
  // ─── STATS COUNTER ───
  function animateCounter(el: Element) {
    const target = parseInt(el.getAttribute('data-target') || '0');
    const duration = 2000;
    const step = target / (duration / 16);
    let current = 0;
 
    const timer = setInterval(() => {
      current += step;
      if (current >= target) {
        el.textContent = target.toLocaleString();
        clearInterval(timer);
      } else {
        el.textContent = Math.floor(current).toLocaleString();
      }
    }, 16);
  }
 
  document.addEventListener('DOMContentLoaded', () => {
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target);
          statObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });
 
    document.querySelectorAll('.stat-number')
      .forEach(el => statObserver.observe(el));
  });
</script>
 