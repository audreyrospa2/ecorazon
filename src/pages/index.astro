---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Ecorazón - Where Nature's Echo Meets the Art with Heart">
  <Header />
  
  <main>

    <!-- Hero Section -->
    <section class="hero-section">
      <img src="/images/grid.png" alt="" class="hero-grid" aria-hidden="true" loading="eager" />
      <div class="hero-content">
        <h1 class="hero-tagline">
          <span>HEARTFELT STORIES</span>
          <span>SUSTAINABLE FUTURE</span>
        </h1>
        <p class="hero-subtitle-zh" lang="zh-Hant">以故事連結人心 · 以永續策展未來</p>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="stat-number-wrap">
              <span class="stat-number" data-target="1500">0</span>
              <span class="stat-plus">+</span>
            </div>
            <p class="stat-label">Audience Engaged</p>
          </div>
          <div class="hero-stat">
            <div class="stat-number-wrap">
              <span class="stat-number" data-target="100">0</span>
              <span class="stat-plus">+</span>
            </div>
            <p class="stat-label">Brands Collaborated</p>
          </div>
          <div class="hero-stat">
            <div class="stat-number-wrap">
              <span class="stat-number" data-target="300">0</span>
              <span class="stat-plus">+</span>
            </div>
            <p class="stat-label">Merchandise Ideas</p>
          </div>
        </div>
      </div>
      <img src="/images/hero-element.png" alt="" class="hero-element" loading="eager" />
    </section>

    <!-- Logo Marquee Bar -->
    <div class="logo-bar">
      <div class="logo-track">
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
        <div class="logo-item"><img src="/images/galagiftlogo.png" alt="Brand" /></div>
      </div>
    </div>

    <!-- About Section -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-color-cork-brown mb-8 tracking-wide about-title">
          ABOUT US
        </h2>
        <p class="text-lg text-gray-700 leading-relaxed about-text">
          Ecorazón is where nature's echo meets the art with heart. We drive a virtuous cycle of good through design thinking and innovative technology — integrating sustainable materials and human creativity to transform empathy into a visible, usable, and empowering force.
        </p>
      </div>
    </section>

    <!-- Sustainable Materials Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-color-cork-brown mb-12 tracking-wide materials-title">
          COMMON SUSTAINABLE MATERIALS WE USE
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-5">
          <div class="material-card">
            <img src="/images/softwood.jpg" alt="Softwood Sawdust" class="w-full h-80 object-cover" />
            <p class="mt-3 text-color-cork-brown">Softwood Sawdust</p>
          </div>
          <div class="material-card">
            <img src="/images/plastic.jpg" alt="Recycled Plastics" class="w-full h-80 object-cover" />
            <p class="mt-3 text-color-cork-brown">Recycled Plastics</p>
          </div>
          <div class="material-card">
            <img src="/images/sugarcane.jpg" alt="Sugarcane Bagasse" class="w-full h-80 object-cover" />
            <p class="mt-3 text-color-cork-brown">Sugarcane Bagasse</p>
          </div>
          <div class="material-card">
            <img src="/images/coffee.jpg" alt="Coffee Grounds" class="w-full h-80 object-cover" />
            <p class="mt-3 text-color-cork-brown">Coffee Grounds</p>
          </div>
          <div class="material-card">
            <img src="/images/ricehusk.jpg" alt="Rice Husk" class="w-full h-80 object-cover" />
            <p class="mt-3 text-color-cork-brown">Rice Husk</p>
          </div>
        </div>
        <p class="mt-8 text-color-cork-brown font-semibold text-base tracking-wide">A HARMONY OF NATURE AND ART</p>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-color-cork-brown mb-8 tracking-wide">
            WHY CHOOSE ECORAZÓN?
          </h2>
          <ul class="space-y-6 text-left">
            <li>
              <h3 class="text-xl font-semibold text-color-cork-brown mb-1">CURATED MICE</h3>
              <p class="text-gray-700">We design meaningful business events and experiences that go beyond meetings — weaving art, culture, and purpose into every gathering.</p>
            </li>
            <li>
              <h3 class="text-xl font-semibold text-color-cork-brown mb-1">CORPORATE GIFTS</h3>
              <p class="text-gray-700">Every product is crafted with eco-friendly materials that nurture the planet.</p>
            </li>
            <li>
              <h3 class="text-xl font-semibold text-color-cork-brown mb-1">WELLNESS INITIATIVES</h3>
              <p class="text-gray-700">Tailored gifts that reflect your brand's unique values and story.</p>
            </li>
            <li>
              <h3 class="text-xl font-semibold text-color-cork-brown mb-1">ESG SOLUTIONS</h3>
              <p class="text-gray-700">Sustainable innovation strategies that align your brand with values that matter — for people, planet, and the communities you serve.</p>
            </li>
          </ul>
        </div>
        <div>
          <img src="/images/green.jpg" alt="Feature Showcase" class="shadow-md" />
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section text-center">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 tracking-wide">
          READY TO CREATE SOMETHING MEANINGFUL?
        </h2>
        <p class="text-lg mb-8 leading-relaxed">
          Let's co-create gifts and experiences that inspire, empower, and sustain.
        </p>
        <a href="/get-in-touch" class="cta-btn">Get in Touch</a>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<style is:global>

  html { scroll-behavior: smooth; }

  /* ─── HERO ─── */
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 560px;
    overflow: hidden;
    background: url('/images/gradient-bg-1.png') center center / cover no-repeat;
    display: flex;
    align-items: flex-start;
    padding: 10% 0 0 clamp(2rem, 6vw, 6rem);
  }

  .hero-grid {
    position: absolute;
    bottom: -15%;
    left: 50%;
    transform: translateX(-50%);
    width: 90%;
    height: 80%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.7;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 50%;
  }

  .hero-tagline {
    display: flex;
    flex-direction: column;
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 3.8rem);
    line-height: 1.1;
    color: #000000;
    margin: 0 0 0.75rem 0;
    letter-spacing: 0;
    white-space: nowrap;
  }

  .hero-tagline span {
    display: block;
    white-space: nowrap;
  }

  .hero-subtitle-zh {
    font-family: 'MaoWei', serif;
    font-size: clamp(0.85rem, 1.2vw, 1.1rem);
    font-weight: 400;
    color: #000000;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .hero-stats {
    display: flex;
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
  }

  .stat-number-wrap {
    display: flex;
    align-items: baseline;
    gap: 1px;
  }

  .stat-number {
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    color: #275D2F;
    line-height: 1;
  }

  .stat-plus {
    font-family: 'MaoWei', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    color: #95BD8D;
    line-height: 1;
    display: inline;
  }

  .stat-label {
    font-family: 'MaoWei', sans-serif;
    font-size: clamp(0.7rem, 1vw, 0.85rem);
    font-weight: 400;
    color: #000000;
    margin-top: 0.25rem;
    opacity: 0.7;
  }

  .hero-element {
    position: absolute;
    right: -10%;
    top: -7%;
    width: 450%;
    max-width: none;
    height: 110%;
    object-fit: contain;
    object-position: top right;
    z-index: 1;
    pointer-events: none;
  }

  /* ─── HERO ENTRANCE ANIMATIONS ─── */
  .hero-tagline,
  .hero-subtitle-zh,
  .hero-stats {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .hero-element {
    opacity: 0;
    transform: translateX(80px);
    transition: opacity 0.9s ease-out, transform 0.9s ease-out;
  }

  .hero-tagline.hero-visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.1s;
  }

  .hero-subtitle-zh.hero-visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.3s;
  }

  .hero-stats.hero-visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.5s;
  }

  @keyframes float {
  0%   { transform: translateY(0px); }
  50%  { transform: translateY(-18px); }
  100% { transform: translateY(0px); }
  } 

  .hero-element.hero-visible {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0.2s;
    animation: float 4s ease-in-out infinite;
  }

  /* ─── LOGO BAR ─── */
  .logo-bar {
    width: 100%;
    overflow: hidden;
    background: #ffffff;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding: 1.5rem 0;
    position: relative;
    z-index: 3;
  }

  .logo-track {
    display: flex;
    align-items: center;
    gap: 3rem;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .logo-bar:hover .logo-track {
    animation-play-state: paused;
  }

  .logo-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-item img {
    height: 36px;
    width: auto;
    filter: grayscale(100%) opacity(0.5);
    transition: filter 0.3s ease;
    pointer-events: none;
  }

  .logo-bar:hover .logo-item img {
    filter: grayscale(0%) opacity(1);
  }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ─── CTA SECTION ─── */
  .cta-section {
    padding: 15rem 0;
    background: linear-gradient(-45deg, #7ACC86, #CE508F, #8AF3FF, #EB9C2E);
    background-size: 400% 400%;
    animation: gradientShift 8s ease infinite;
    color: #ffffff;
  }

  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .cta-btn {
    display: inline-block;
    background: #ffffff;
    color: #000000;
    padding: 0.75rem 2rem;
    border-radius: 0px;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-btn:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }

  /* ─── SCROLL ANIMATIONS ─── */
  .about-title, .about-text, .materials-title, .material-card {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .about-title.visible  { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .about-text.visible   { opacity: 1; transform: translateY(0); transition-delay: 0.3s; }
  .materials-title.visible { opacity: 1; transform: translateY(0); transition-delay: 0.1s; }
  .material-card.visible   { opacity: 1; transform: translateY(0); }

  .material-card:nth-child(1).visible { transition-delay: 0.1s; }
  .material-card:nth-child(2).visible { transition-delay: 0.2s; }
  .material-card:nth-child(3).visible { transition-delay: 0.3s; }
  .material-card:nth-child(4).visible { transition-delay: 0.4s; }
  .material-card:nth-child(5).visible { transition-delay: 0.5s; }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    .hero-section {
      align-items: flex-start;
      padding: 5rem 1.5rem 0;
      height: auto;
      min-height: 100svh;
      flex-direction: column;
    }

    .hero-content {
      max-width: 100%;
      order: 1;
    }

    .hero-tagline {
      font-size: clamp(1.4rem, 6vw, 1.8rem);
      white-space: normal;
    }

    .hero-element {
      position: relative;
      right: unset;
      top: unset;
      width: 130vw;
      height: auto;
      margin: 4rem -50vw 0rem -30vw;
      display: block;
      order: 2;
      z-index: 2;
      /* keep animation transform reset intact on mobile */
      transform: translateX(80px);
    }

    .hero-element.hero-visible {
    transform: translateX(0);
    animation: float 4s ease-in-out infinite;
    }

    .hero-grid { opacity: 0.3; }

    .hero-stats {
      margin-top: 0.75rem;
      gap: 1rem;
    }
  }

</style>

<script>
  // ─── SCROLL REVEAL ───
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.2, rootMargin: '0px 0px -50px 0px' });

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.about-title, .about-text, .materials-title, .material-card')
      .forEach(el => observer.observe(el));
  });

  // ─── HERO ENTRANCE ───
  document.addEventListener('DOMContentLoaded', () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        document.querySelectorAll('.hero-tagline, .hero-subtitle-zh, .hero-stats, .hero-element')
          .forEach(el => el.classList.add('hero-visible'));
      });
    });
  });

  // ─── STATS COUNTER ───
  function animateCounter(el) {
    const target = parseInt(el.getAttribute('data-target'));
    const duration = 2000;
    const step = target / (duration / 16);
    let current = 0;

    const timer = setInterval(() => {
      current += step;
      if (current >= target) {
        el.textContent = target.toLocaleString();
        clearInterval(timer);
      } else {
        el.textContent = Math.floor(current).toLocaleString();
      }
    }, 16);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounter(entry.target);
          statObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('.stat-number')
      .forEach(el => statObserver.observe(el));
  });
</script>