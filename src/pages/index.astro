---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Ecorazón - Where Nature's Echo Meets the Art with Heart">
  <Header />
  
  <main class="font-serif">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-grid">
        <div class="grid-lines"></div>
      </div>

      <div class="hero-content">
        <h1 class="hero-tagline">
          <span class="hero-tagline-line">HEARTFELT STORIES</span>
          <span class="hero-tagline-line">SUSTAINABLE FUTURE</span>
        </h1>
        <p class="hero-subtitle-zh" lang="zh-Hant">以故事連結人心 · 以永續策展未來</p>
      </div>

      <img
        src="/images/hero-element.png"
        alt=""
        class="hero-element"
        width="700"
        height="700"
        loading="eager"
      />
    </section>

    <!-- Introduction Section -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-forest-green mb-8 tracking-wide about-title">
          About Us
        </h2>
        <p class="text-lg text-gray-700 leading-relaxed about-text">
          At Ecorazón, we create custom corporate gifts designed by artists with special needs. Each product combines quality craftsmanship, sustainable materials, and meaningful design to help your brand make a lasting impression while supporting social impact.
        </p>
      </div>
    </section>

    <!-- Sustainable Materials Section -->
    <section class="py-20 bg-warm-beige">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-forest-green mb-12 tracking-wide materials-title">
          Common Sustainable Materials We Use
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-5">
          <div class="material-card">
            <img src="/images/softwood.jpg" alt="Softwood Sawdust" class="w-full h-80 object-cover" />
            <p class="mt-3 text-forest-green font-semibold">Softwood Sawdust</p>
          </div>
          <div class="material-card">
            <img src="/images/plastic.jpg" alt="Recycled Plastics" class="w-full h-80 object-cover" />
            <p class="mt-3 text-forest-green font-semibold">Recycled Plastics</p>
          </div>
          <div class="material-card">
            <img src="/images/sugarcane.jpg" alt="Sugarcane Bagasse" class="w-full h-80 object-cover" />
            <p class="mt-3 text-forest-green font-semibold">Sugarcane Bagasse</p>
          </div>
          <div class="material-card">
            <img src="/images/coffee.jpg" alt="Coffee Grounds" class="w-full h-80 object-cover" />
            <p class="mt-3 text-forest-green font-semibold">Coffee Grounds</p>
          </div>
          <div class="material-card">
            <img src="/images/ricehusk.jpg" alt="Rice Husk" class="w-full h-80 object-cover" />
            <p class="mt-3 text-forest-green font-semibold">Rice Husk</p>
          </div>
        </div>

        <p class="mt-8 text-forest-green text-base tracking-wide">
          A harmony of nature and art
        </p>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 bg-white">
      <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-forest-green mb-8 tracking-wide">
            Why Choose Ecorazón?
          </h2>
          <ul class="space-y-6 text-left">
            <li>
              <h3 class="text-xl font-semibold text-forest-green mb-1">🎨 Empowering Creators</h3>
              <p class="text-gray-700">We collaborate with artists with special needs, amplifying their voices and talents.</p>
            </li>
            <li>
              <h3 class="text-xl font-semibold text-forest-green mb-1">🌍 Sustainability First</h3>
              <p class="text-gray-700">Every product is crafted with eco-friendly materials that nurture the planet.</p>
            </li>
            <li>
              <h3 class="text-xl font-semibold text-forest-green mb-1">✨ Bespoke Creations</h3>
              <p class="text-gray-700">Tailored gifts that reflect your brand's unique values and story.</p>
            </li>
            <li>
              <h3 class="text-xl font-semibold text-forest-green mb-1">🤝 Meaningful Partnerships</h3>
              <p class="text-gray-700">We align with ESG goals, co-creating a positive and lasting impact.</p>
            </li>
          </ul>
        </div>
        <div>
          <img src="/images/green.jpg" alt="Feature Showcase" class="rounded-lg shadow-md" />
        </div>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section class="py-20 cta-section text-black text-center">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 tracking-wide">
          Ready to Create Something Meaningful?
        </h2>
        <p class="text-lg mb-8 leading-relaxed">
          Let's co-create gifts and experiences that inspire, empower, and sustain.
        </p>
        <a href="/get-in-touch" class="inline-block bg-white text-black px-8 py-3 rounded-md text-lg font-semibold transition-all duration-300 btn-float">
          Get in Touch
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  /* Scroll-triggered animations */
  .about-title,
  .about-text,
  .materials-title,
  .material-card {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .about-title.visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.1s;
  }

  .about-text.visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.3s;
  }

  .materials-title.visible {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.1s;
  }

  .material-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .material-card:nth-child(1).visible { transition-delay: 0.1s; }
  .material-card:nth-child(2).visible { transition-delay: 0.2s; }
  .material-card:nth-child(3).visible { transition-delay: 0.3s; }
  .material-card:nth-child(4).visible { transition-delay: 0.4s; }
  .material-card:nth-child(5).visible { transition-delay: 0.5s; }

  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }

  /* Button float effect */
  .btn-float {
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .btn-float:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  /* CTA section button hover */
  .cta-section .btn-float:hover {
    background-color: #f3f4f6;
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const observerOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, observerOptions);

  // Observe all animated elements
  document.addEventListener('DOMContentLoaded', () => {
    const elementsToAnimate = document.querySelectorAll(
      '.about-title, .about-text, .materials-title, .material-card'
    );
    
    elementsToAnimate.forEach(el => observer.observe(el));
  });
</script>
