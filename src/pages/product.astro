---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Product - Ecorazón">
  <Header />

  <main>
    <section class="bg-gradient-to-br from-warm-beige to-gray-100 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-forest-green mb-6">
          Product
        </h1>
        <p class="text-xl text-gray-700 max-w-3xl mx-auto">
          Content coming soon.
        </p>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <p class="text-lg text-gray-700 leading-relaxed">
          Explore our sustainable corporate gifts and bespoke creations designed with heart.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
