---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Services - Ecorazón">
  <Header />

  <main class="services-page">

    <!-- Hero -->
    <section class="services-hero">
      <div class="services-hero-content">
        <h1 class="services-hero-title animate-fade-in">Our Services</h1>
        <p class="services-hero-sub animate-fade-in-delay">Custom corporate gifts for brands that care — about people, planet, and purpose.</p>
      </div>
    </section>

    <!-- Intro -->
    <section class="svc-section bg-white">
      <div class="svc-inner">
        <p class="intro-text scroll-reveal">
          We design and produce premium corporate gifts that reflect your brand identity while prioritizing sustainability and social responsibility. From client appreciation to employee recognition, our products tell your story with purpose.
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="svc-section bg-white">
      <div class="svc-inner">
        <div class="services-grid">

          <div class="svc-card scroll-reveal">
            <div class="svc-img-wrap">
              <img src="/images/4.png" alt="Corporate Gift Solutions" class="svc-img" />
            </div>
            <div class="svc-info">
              <div class="svc-icon">🎁</div>
              <h3 class="svc-name">Corporate Gift Solutions</h3>
              <p class="svc-desc">Personalized gifts that strengthen business relationships and showcase your commitment to sustainability and inclusivity.</p>
              <ul class="svc-list">
                <li>Custom design consultation</li>
                <li>Eco-friendly material options</li>
                <li>Artist collaboration</li>
                <li>Brand alignment & storytelling</li>
                <li>Bulk ordering capabilities</li>
              </ul>
              <a href="/get-in-touch" class="svc-cta">Enquire</a>
            </div>
          </div>

          <div class="svc-card scroll-reveal">
            <div class="svc-img-wrap">
              <img src="/images/6.png" alt="Exclusive Branded Merchandise" class="svc-img" />
            </div>
            <div class="svc-info">
              <div class="svc-icon">🏷️</div>
              <h3 class="svc-name">Exclusive Branded Merchandise</h3>
              <p class="svc-desc">Exclusive branded products that blend creativity and sustainability — functional, beautiful, and perfect for events and campaigns.</p>
              <ul class="svc-list">
                <li>Product design & development</li>
                <li>Eco-friendly materials</li>
                <li>Functional & aesthetic appeal</li>
                <li>Scalable production</li>
              </ul>
              <a href="/get-in-touch" class="svc-cta">Enquire</a>
            </div>
          </div>

          <div class="svc-card scroll-reveal">
            <div class="svc-img-wrap">
              <img src="/images/14.png" alt="Co-Branded Creations" class="svc-img" />
            </div>
            <div class="svc-info">
              <div class="svc-icon">🤝</div>
              <h3 class="svc-name">Co-Branded Creations</h3>
              <p class="svc-desc">We collaborate with brands to launch co-branded designs, merging art and eco-conscious values into meaningful, memorable products.</p>
              <ul class="svc-list">
                <li>Partnership development</li>
                <li>Collaborative design process</li>
                <li>Joint marketing opportunities</li>
                <li>Shared values alignment</li>
              </ul>
              <a href="/get-in-touch" class="svc-cta">Enquire</a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="svc-section bg-white">
      <div class="svc-inner">
        <div class="section-header scroll-reveal">
          <h2 class="section-title">Our Creative Process</h2>
          <p class="section-sub">From concept to creation, every step reflects our commitment to sustainability and empowerment.</p>
        </div>
        <div class="process-grid">
          <div class="process-step scroll-reveal">
            <div class="step-number" style="background:#95BD8D">1</div>
            <h3 class="step-title">Consultation</h3>
            <p class="step-desc">Understanding your brand values and vision</p>
          </div>
          <div class="process-step scroll-reveal">
            <div class="step-number" style="background:#6b8f76">2</div>
            <h3 class="step-title">Design</h3>
            <p class="step-desc">Collaborative creation with our artists</p>
          </div>
          <div class="process-step scroll-reveal">
            <div class="step-number" style="background:#a07850">3</div>
            <h3 class="step-title">Creation</h3>
            <p class="step-desc">Sustainable crafting with eco-friendly materials</p>
          </div>
          <div class="process-step scroll-reveal">
            <div class="step-number" style="background:#95BD8D">4</div>
            <h3 class="step-title">Delivery</h3>
            <p class="step-desc">Thoughtful packaging and timely delivery</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Us -->
    <section class="svc-section bg-dark">
      <div class="svc-inner">
        <div class="section-header scroll-reveal">
          <h2 class="section-title white">Why Partner with Ecorazón?</h2>
        </div>
        <div class="why-grid">
          <div class="why-card scroll-reveal">
            <div class="why-icon">🌱</div>
            <h3 class="why-title">Sustainability Focus</h3>
            <p class="why-desc">Every creation uses eco-friendly materials and processes</p>
          </div>
          <div class="why-card scroll-reveal">
            <div class="why-icon">🎨</div>
            <h3 class="why-title">Artistic Excellence</h3>
            <p class="why-desc">Collaborating with talented special needs artists</p>
          </div>
          <div class="why-card scroll-reveal">
            <div class="why-icon">📈</div>
            <h3 class="why-title">ESG Alignment</h3>
            <p class="why-desc">Supporting your environmental and social goals</p>
          </div>
          <div class="why-card scroll-reveal">
            <div class="why-icon">✨</div>
            <h3 class="why-title">Unique Impact</h3>
            <p class="why-desc">Creating meaningful connections with your stakeholders</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="svc-section bg-white">
      <div class="svc-inner cta-inner">
        <h2 class="section-title scroll-reveal">Ready to Create Something Meaningful?</h2>
        <p class="section-sub scroll-reveal">Let's discuss how we can bring your vision to life through sustainable, artistic corporate gifts.</p>
        <a href="/get-in-touch" class="svc-cta large scroll-reveal">Start Your Project</a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  .services-page {
    padding-top: 72px;
  }

  /* ─── HERO ─── */
  .services-hero {
    background: url('/images/green-purple.png') center center / cover no-repeat;
    padding: 6rem clamp(2rem, 8vw, 7rem);
    min-height: 260px;
    display: flex;
    align-items: flex-end;
  }

  .services-hero-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: #000000;
    margin: 0 0 0.5rem 0;
    line-height: 1.1;
  }

  .services-hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: #000000;
    opacity: 0.7;
    margin: 0;
    max-width: 500px;
  }

  /* ─── HERO ANIMATION ─── */
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in       { animation: fadeInDown 0.8s ease-out 0.2s both; }
  .animate-fade-in-delay { animation: fadeInDown 0.8s ease-out 0.4s both; }

  /* ─── SECTIONS ─── */
  .svc-section {
    padding: 5rem clamp(2rem, 6vw, 6rem);
  }

  .bg-white { background: #ffffff; }
  .bg-warm  { background: #f7f5f0; }
  .bg-dark  { background: #95BD8D; }

  .svc-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ─── INTRO ─── */
  .intro-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.1rem;
    color: #000000;
    opacity: 0.65;
    line-height: 1.9;
    max-width: 760px;
  }

  /* ─── SECTION HEADER ─── */
  .section-header {
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    color: #000000;
    margin: 0 0 0.75rem 0;
    line-height: 1.15;
  }

  .section-title.white { color: #ffffff; }

  .section-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #000000;
    opacity: 0.6;
    margin: 0;
    max-width: 560px;
    line-height: 1.7;
  }

  /* ─── SERVICES GRID ─── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .svc-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0,0,0,0.08);
    background: #ffffff;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .svc-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-4px);
  }

  .svc-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #f0f4f0;
  }

  .svc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .svc-card:hover .svc-img {
    transform: scale(1.03);
  }

  .svc-info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .svc-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .svc-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
    margin: 0 0 0.5rem 0;
  }

  .svc-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: #000000;
    opacity: 0.6;
    line-height: 1.6;
    margin: 0 0 1rem 0;
  }

  .svc-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .svc-list li {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    color: #000000;
    opacity: 0.55;
    padding-left: 1rem;
    position: relative;
  }

  .svc-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    opacity: 0.4;
  }

  .svc-cta {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    background: #95BD8D;
    text-decoration: none;
    padding: 0.5rem 1.25rem;
    align-self: flex-start;
    transition: background 0.2s ease;
  }

  .svc-cta:hover {
    background: #C08EA4;
  }

  .svc-cta.large {
    font-size: 1rem;
    padding: 0.75rem 2rem;
    margin-top: 1.5rem;
  }

  /* ─── PROCESS ─── */
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1.5rem;
    border: 1px solid rgba(0,0,0,0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .process-step:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
    transform: translateY(-4px);
  }

  .step-number {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #ffffff;
    margin-bottom: 1rem;
    flex-shrink: 0;
  }

  .step-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #000000;
    margin: 0 0 0.4rem 0;
  }

  .step-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    color: #000000;
    opacity: 0.55;
    margin: 0;
    line-height: 1.6;
  }

  /* ─── WHY US ─── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .why-card {
    padding: 1.75rem;
    border: 1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.08);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .why-card:hover {
    background: rgba(255,255,255,0.18);
    transform: translateY(-4px);
  }

  .why-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .why-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #ffffff;
    margin: 0 0 0.4rem 0;
  }

  .why-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    color: #ffffff;
    opacity: 0.8;
    margin: 0;
    line-height: 1.6;
  }

  /* ─── CTA ─── */
  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* ─── SCROLL REVEAL ─── */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .services-grid .svc-card:nth-child(1) { transition-delay: 0.1s; }
  .services-grid .svc-card:nth-child(2) { transition-delay: 0.25s; }
  .services-grid .svc-card:nth-child(3) { transition-delay: 0.4s; }

  .process-grid .process-step:nth-child(1) { transition-delay: 0.1s; }
  .process-grid .process-step:nth-child(2) { transition-delay: 0.2s; }
  .process-grid .process-step:nth-child(3) { transition-delay: 0.3s; }
  .process-grid .process-step:nth-child(4) { transition-delay: 0.4s; }

  .why-grid .why-card:nth-child(1) { transition-delay: 0.1s; }
  .why-grid .why-card:nth-child(2) { transition-delay: 0.2s; }
  .why-grid .why-card:nth-child(3) { transition-delay: 0.3s; }
  .why-grid .why-card:nth-child(4) { transition-delay: 0.4s; }

  /* ─── MOBILE ─── */
  @media (max-width: 1024px) {
    .process-grid,
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .process-grid,
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .process-grid,
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
  });
</script>