---
---
<header class="header-wrap">
  <nav class="header-nav">
    <div class="header-inner">

      <!-- Logo -->
      <a href="/" class="header-logo">
        <img src="/images/Logo-long.png" alt="Ecorazón" class="logo-img" />
      </a>

      <!-- Desktop Navigation -->
      <div class="desktop-nav">
        <a href="/" class="nav-link i18n-text" data-zh="首頁">Home</a>
        <a href="/about" class="nav-link i18n-text" data-zh="關於我們">About</a>
        <a href="/event" class="nav-link i18n-text" data-zh="活動">Event</a>
        <a href="/product" class="nav-link i18n-text" data-zh="產品">Product</a>
        <a href="/programme" class="nav-link i18n-text" data-zh="企劃">Programme</a>
        <a href="/resources" class="nav-link i18n-text" data-zh="資源">Resources</a>
        <a href="/get-in-touch" class="nav-cta i18n-text" data-zh="聯絡我們">Get in Touch</a>
      </div>

      <!-- Desktop language toggle -->
      <button class="lang-toggle lang-toggle-desktop" aria-label="Switch language / 切換語言">
        <span class="lang-toggle-en">EN</span>
        <span class="lang-toggle-sep">/</span>
        <span class="lang-toggle-zh">中文</span>
      </button>

      <!-- Mobile menu button -->
      <button id="mobile-menu-button" class="mobile-menu-btn" aria-label="Toggle menu">
        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="mobile-nav hidden">
      <a href="/" class="mobile-nav-link i18n-text" data-zh="首頁">Home</a>
      <a href="/about" class="mobile-nav-link i18n-text" data-zh="關於我們">About</a>
      <a href="/event" class="mobile-nav-link i18n-text" data-zh="活動">Event</a>
      <a href="/product" class="mobile-nav-link i18n-text" data-zh="產品">Product</a>
      <a href="/programme" class="mobile-nav-link i18n-text" data-zh="企劃">Programme</a>
      <a href="/resources" class="mobile-nav-link i18n-text" data-zh="資源">Resources</a>

      <button class="lang-toggle lang-toggle-mobile" aria-label="Switch language / 切換語言">
        <span class="lang-toggle-en">EN</span>
        <span class="lang-toggle-sep">/</span>
        <span class="lang-toggle-zh">中文</span>
      </button>

      <a href="/get-in-touch" class="mobile-nav-cta i18n-text" data-zh="聯絡我們">Get in Touch</a>
    </div>
  </nav>
</header>

<style>
  .header-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
}

  .header-nav {
    width: 100%;
    padding: 0 50px;
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 72px;
    position: relative;
  }

  .header-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    height: 48px;
    width: auto;
  }

  /* Desktop nav — absolutely centered against full header width */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-link {
    font-family: 'MaoWei', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: #000000;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .nav-link:hover {
    background: rgba(149, 189, 141, 0.12);
    color: #000000;
  }

  /* CTA sits in normal flow, pushed to the right */
  .nav-cta {
  font-family: 'MaoWei', sans-serif;
  font-size: 0.95rem;
  font-weight: 500;
  color: #87c090;
  text-decoration: none;
  padding: 0.3rem 1rem;
  border: 2px solid #87c090;
  border-radius: 0;
  transition: background 0.2s ease;
  white-space: nowrap;
  }

  .nav-cta:hover {
    background: #87c090;
    color: #ffffff;
  }

  /* ─── LANGUAGE TOGGLE ─── */
  .lang-toggle {
    font-family: 'MaoWei', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    background: none;
    border: 1px solid rgba(0, 0, 0, 0.25);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    cursor: pointer;
    color: #000000;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    line-height: 1;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .lang-toggle:hover {
    border-color: #87c090;
    background: rgba(149, 189, 141, 0.12);
  }

  .lang-toggle-sep {
    opacity: 0.4;
  }

  .lang-toggle-en,
  .lang-toggle-zh {
    opacity: 0.45;
    transition: opacity 0.2s ease, font-weight 0.2s ease;
  }

  /* highlight whichever language is currently active */
  html[data-lang="en"] .lang-toggle-en,
  html[data-lang="zh"] .lang-toggle-zh {
    opacity: 1;
    font-weight: 700;
  }

  .lang-toggle-desktop {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
  }

  .lang-toggle-mobile {
    display: none;
    align-self: flex-start;
    margin: 0.25rem 0 0.25rem 0.75rem;
  }

  /* Mobile btn */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: #000000;
    padding: 0.25rem;
  }

  /* Mobile nav */
  .mobile-nav {
    padding: 0.75rem 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav.hidden {
    display: none;
  }

  .mobile-nav-link {
    font-family: 'MaoWei', sans-serif;
    font-size: 0.95rem;
    color: #000000;
    text-decoration: none;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    transition: background 0.2s ease;
  }

  .mobile-nav-link:hover {
    background: rgba(149, 189, 141, 0.12);
  }

  .mobile-nav-cta {
    font-family: 'MaoWei', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: #ffffff;
    background: #95BD8D;
    text-decoration: none;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    margin-top: 0.25rem;
    transition: background 0.2s ease;
  }

  .mobile-nav-cta:hover {
    background: #C08EA4;
  }

  @media (max-width: 768px) {
    .header-wrap {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }

  .desktop-nav,
  .nav-cta,
  .lang-toggle-desktop {
    display: none;
  }

  .lang-toggle-mobile {
    display: flex;
  }

  .mobile-menu-btn {
    display: block;
    margin-left: auto;
  }

  .mobile-nav-cta {
  font-family: 'MaoWei', sans-serif;
  font-size: 0.95rem;
  font-weight: 500;
  color: #87c090;
  background: transparent;
  text-decoration: none;
  padding: 0.6rem 0.75rem;
  border: 2px solid #87c090;
  border-radius: 0;
  margin-top: 0.25rem;
  transition: background 0.2s ease, color 0.2s ease;
  white-space: nowrap;
  display: inline-block;
}

.mobile-nav-cta:hover {
  background: #87c090;
  color: #ffffff;
}
  }
</style>

<script>
  // ─── MOBILE MENU ───
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // ─── SITE-WIDE LANGUAGE TOGGLE ───
  // Any element with class "i18n-text" and a data-zh="..." attribute will be
  // swapped between its original (English) text and the Chinese translation.
  // Works on every page, because Header is rendered on every page.
  const LANG_KEY = 'ecorazon-lang';

  function applyLang(lang: string) {
    document.querySelectorAll<HTMLElement>('.i18n-text').forEach((el) => {
      if (el.dataset.en === undefined) {
        // cache the original English text the first time we touch this element
        el.dataset.en = el.textContent || '';
      }
      el.textContent = lang === 'zh' ? (el.dataset.zh || el.dataset.en || '') : (el.dataset.en || '');
    });
    document.documentElement.setAttribute('data-lang', lang);
  }

  function getSavedLang(): string {
    try {
      return localStorage.getItem(LANG_KEY) || 'en';
    } catch {
      return 'en';
    }
  }

  function setSavedLang(lang: string) {
    try {
      localStorage.setItem(LANG_KEY, lang);
    } catch {
      // localStorage unavailable — toggle will still work for this page view
    }
  }

  // Apply saved preference as soon as this script runs on every page load
  applyLang(getSavedLang());

  document.querySelectorAll<HTMLButtonElement>('.lang-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-lang') || 'en';
      const next = current === 'en' ? 'zh' : 'en';
      applyLang(next);
      setSavedLang(next);
    });
  });
</script>